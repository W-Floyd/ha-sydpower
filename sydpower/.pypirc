# Distribution section for PyPI credentials
# Save this file as ~/.pypirc and configure your credentials
#
# To use with twine: twine upload dist/*
# To specify a repository: twine upload --repository pypi dist/*

[pypi]
username = __token__
password = pypi-YOUR_PYPI_API_TOKEN

[testpypi]
username = __token__
password = pypi-TEST_PYPI_API_TOKEN

# Note: For PyPI, use the token format:
#   username = __token__
#   password = pypi-YOUR_ACTUAL_TOKEN
#
# For TestPyPI, use the same format with your TestPyPI token.
#
# Alternatively, you can store credentials in environment variables:
#   export TWINE_USERNAME=__token__
#   export TWINE_PASSWORD=pypi-YOUR_TOKEN
